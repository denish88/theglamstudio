{
  "name": "theglamserver",
  "version": "1.0.0",
  "description": "The Glam Club — Backend API Server",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --config nodemon.json src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "seed": "node src/seed.js",
    "migrate:payment-collector": "node src/scripts/backfillPaymentCollector.js",
    "build:client": "cd ../theglam && npm run build && rm -rf ../theglamserver/public && mv dist ../theglamserver/public"
  },
